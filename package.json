{
  "name": "edge-form-inbox",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "db:migrate:local": "wrangler d1 migrations apply edge-form-inbox --local",
    "db:migrate:remote": "wrangler d1 migrations apply edge-form-inbox --remote",
    "db:execute:local": "wrangler d1 execute edge-form-inbox --local --command",
    "db:execute:remote": "wrangler d1 execute edge-form-inbox --remote --command"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260617.0",
    "typescript": "^5.8.3",
    "vitepress": "^1.6.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.20.5"
  }
}
